{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://locklane.dev/schemas/verification_report.schema.json",
  "title": "VerificationReport",
  "type": "object",
  "required": [
    "schema_version",
    "timestamp_utc",
    "resolver",
    "status",
    "manifest_path",
    "verification"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "timestamp_utc": { "type": "string" },
    "resolver": {
      "type": "string",
      "enum": ["uv", "pip-tools"]
    },
    "status": {
      "type": "string",
      "enum": ["ok", "error"]
    },
    "manifest_path": { "type": "string" },
    "plan_path": { "type": "string" },
    "verification": {
      "type": "object",
      "required": ["passed"],
      "properties": {
        "command": { "type": "string" },
        "passed": { "type": "boolean" },
        "exit_code": { "type": "integer" },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "summary": { "type": "string" },
        "venv_path": { "type": "string" },
        "modified_manifest_path": { "type": "string" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "command", "passed", "exit_code", "stdout", "stderr", "duration_seconds"],
            "properties": {
              "name": { "type": "string" },
              "command": { "type": "string" },
              "passed": { "type": "boolean" },
              "exit_code": { "type": "integer" },
              "stdout": { "type": "string" },
              "stderr": { "type": "string" },
              "duration_seconds": { "type": "number" }
            }
          }
        }
      }
    }
  }
}
