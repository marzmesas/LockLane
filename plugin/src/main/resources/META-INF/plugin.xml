<idea-plugin>
    <id>io.locklane.plugin</id>
    <name>Locklane</name>
    <vendor email="mmesasro@gmail.com" url="https://github.com/marzmesas">Locklane</vendor>

    <description><![CDATA[
        <p>Locklane plans safe Python dependency updates for requirements files with conflict-aware guidance.</p>
        <p>Analyses pinned dependencies, simulates upgrades, and generates verified update plans.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                id="Locklane"
                anchor="right"
                factoryClass="io.locklane.LocklaneToolWindowFactory"
                canCloseContents="false"
                icon="/icons/locklaneToolWindow.svg"/>

        <projectConfigurable
                parentId="tools"
                instance="io.locklane.settings.LocklaneConfigurable"
                id="io.locklane.settings"
                displayName="Locklane"
                nonDefaultProject="true"/>
        <projectService serviceImplementation="io.locklane.settings.LocklaneSettings"/>
        <projectService serviceImplementation="io.locklane.service.ResolverService"/>

        <notificationGroup id="Locklane" displayType="BALLOON"/>
    </extensions>
</idea-plugin>

